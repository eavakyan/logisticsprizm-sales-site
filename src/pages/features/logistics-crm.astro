---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FinalCTA from '@/components/sections/FinalCTA.astro';
import { CALENDLY_URL } from '@/lib/links';

const title = 'Logistics CRM with AI Lead Scoring | LogisticsPrizm';
const description = 'Purpose-built CRM for freight forwarders with AI lead scoring, customer management, and sales pipeline tracking. Convert more logistics leads into customers.';
---
<BaseLayout
  title={title}
  description={description}
  breadcrumbs={[
    { name: 'Home', url: 'https://logisticsprizm.com/' },
    { name: 'Features', url: 'https://logisticsprizm.com/features' },
    { name: 'Logistics CRM', url: 'https://logisticsprizm.com/features/logistics-crm' },
  ]}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'LogisticsPrizm Logistics CRM',
    description: 'Purpose-built CRM for freight forwarders with AI lead scoring, customer management, and sales pipeline tracking.',
    provider: { '@type': 'Organization', name: 'LogisticsPrizm' },
    serviceType: 'Logistics CRM Software',
    areaServed: 'Worldwide',
    url: 'https://logisticsprizm.com/features/logistics-crm',
  })} />

  <!-- Hero -->
  <section class="pt-24 pb-16 bg-surface-50">
    <div class="max-w-4xl mx-auto px-6">
      <p class="eyebrow">Feature · Purpose-built for logistics</p>
      <h1 class="mt-3 text-h1 font-bold text-navy-900">The CRM built for <span class="gradient-amber">freight forwarders</span>.</h1>
      <p class="mt-5 text-lg text-navy-900/80 max-w-prose">
        Generic CRMs don't understand logistics. LogisticsPrizm CRM speaks your language — lanes, modes,
        shipment volumes, and carrier relationships. With AI lead scoring that knows which prospects will actually book.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a href={CALENDLY_URL} target="_blank" rel="noopener" class="inline-flex justify-center items-center gap-2 px-6 py-3 rounded-lg bg-prizm-500 text-white font-semibold hover:bg-prizm-600 transition-colors shadow-sm">
          Book my demo <span aria-hidden>→</span>
        </a>
        <a href="/features/ai-freight-quoting" class="inline-flex justify-center items-center gap-2 px-6 py-3 rounded-lg border border-black/10 text-navy-900 font-semibold hover:bg-white transition-colors">
          Explore more features
        </a>
      </div>
    </div>
  </section>

  <!-- AI Lead Scoring -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="eyebrow reveal">AI lead scoring</p>
      <h2 class="mt-3 text-h2 font-bold text-navy-900 reveal">Stop guessing which leads are worth pursuing.</h2>
      <p class="mt-4 text-navy-900/75 max-w-prose reveal">Our AI scores every lead on a 0–100 scale using six logistics-specific factors.</p>

      <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="rounded-xl border border-black/10 bg-surface-50 p-6 reveal">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-base font-semibold text-navy-900">Company revenue</h3>
            <span class="text-xs font-bold text-prizm-700 bg-prizm-50 px-2 py-1 rounded-full">0–20 pts</span>
          </div>
          <p class="text-sm text-navy-900/75 leading-relaxed">Larger companies ship more volume and have higher lifetime value. Revenue is enriched automatically from business databases.</p>
        </div>
        <div class="rounded-xl border border-black/10 bg-surface-50 p-6 reveal">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-base font-semibold text-navy-900">Industry match</h3>
            <span class="text-xs font-bold text-prizm-700 bg-prizm-50 px-2 py-1 rounded-full">0–15 pts</span>
          </div>
          <p class="text-sm text-navy-900/75 leading-relaxed">The AI learns which verticals convert best for your organization and prioritizes accordingly.</p>
        </div>
        <div class="rounded-xl border border-black/10 bg-surface-50 p-6 reveal">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-base font-semibold text-navy-900">Engagement level</h3>
            <span class="text-xs font-bold text-prizm-700 bg-prizm-50 px-2 py-1 rounded-full">0–20 pts</span>
          </div>
          <p class="text-sm text-navy-900/75 leading-relaxed">Track website visits, email opens, quote requests, and portal logins. High-engagement leads get prioritized.</p>
        </div>
        <div class="rounded-xl border border-black/10 bg-surface-50 p-6 reveal">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-base font-semibold text-navy-900">Source quality</h3>
            <span class="text-xs font-bold text-prizm-700 bg-prizm-50 px-2 py-1 rounded-full">0–15 pts</span>
          </div>
          <p class="text-sm text-navy-900/75 leading-relaxed">Referrals and inbound RFQs convert at higher rates than cold lists. The AI weights each source by historical performance.</p>
        </div>
        <div class="rounded-xl border border-black/10 bg-surface-50 p-6 reveal">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-base font-semibold text-navy-900">Shipment volume</h3>
            <span class="text-xs font-bold text-prizm-700 bg-prizm-50 px-2 py-1 rounded-full">0–15 pts</span>
          </div>
          <p class="text-sm text-navy-900/75 leading-relaxed">Estimated shipping volume based on company size, industry, and stated needs. High-volume shippers drive more revenue.</p>
        </div>
        <div class="rounded-xl border border-black/10 bg-surface-50 p-6 reveal">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-base font-semibold text-navy-900">Recency</h3>
            <span class="text-xs font-bold text-prizm-700 bg-prizm-50 px-2 py-1 rounded-full">0–15 pts</span>
          </div>
          <p class="text-sm text-navy-900/75 leading-relaxed">Recent inquiries are worth more than stale leads. Scores decay over time, keeping your pipeline focused on active prospects.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Customer Management -->
  <section class="bg-surface-50 py-20">
    <div class="max-w-5xl mx-auto px-6">
      <p class="eyebrow reveal">Complete customer management</p>
      <h2 class="mt-3 text-h2 font-bold text-navy-900 reveal">Every interaction, shipment, and document in one place.</h2>

      <div class="mt-12 grid md:grid-cols-2 gap-6">
        <div class="rounded-xl bg-white border border-black/10 p-7 reveal">
          <h3 class="text-lg font-semibold text-navy-900">Rich customer profiles</h3>
          <p class="mt-2 text-sm text-navy-900/75 leading-relaxed">Company details, contact hierarchy, preferred lanes, rate agreements, shipment history, and communication log — unified in one profile. Know your customer before every interaction.</p>
        </div>
        <div class="rounded-xl bg-white border border-black/10 p-7 reveal">
          <h3 class="text-lg font-semibold text-navy-900">Full shipment history</h3>
          <p class="mt-2 text-sm text-navy-900/75 leading-relaxed">Every quote, booking, and shipment tied to the customer record. Spot trends in volume, seasonal patterns, and preferred service types to proactively offer the right solutions.</p>
        </div>
        <div class="rounded-xl bg-white border border-black/10 p-7 reveal">
          <h3 class="text-lg font-semibold text-navy-900">Document management</h3>
          <p class="mt-2 text-sm text-navy-900/75 leading-relaxed">Store bills of lading, commercial invoices, customs documents, and rate agreements directly on customer and shipment records. AI-powered OCR extracts key data automatically.</p>
        </div>
        <div class="rounded-xl bg-white border border-black/10 p-7 reveal">
          <h3 class="text-lg font-semibold text-navy-900">Integrated communication</h3>
          <p class="mt-2 text-sm text-navy-900/75 leading-relaxed">Real-time chat, email tracking, and activity feed for every customer. Your whole team sees the same conversation history — no more "what did we tell this customer?"</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pipeline -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-6">
      <p class="eyebrow reveal">From lead to booked shipment</p>
      <h2 class="mt-3 text-h2 font-bold text-navy-900 reveal">Track every prospect through a logistics-specific pipeline.</h2>

      <div class="mt-10 flex flex-col md:flex-row items-stretch gap-3 reveal">
        <div class="flex-1 rounded-xl bg-surface-50 border border-black/10 p-5 text-center">
          <div class="w-9 h-9 rounded-full bg-white border border-black/10 flex items-center justify-center mx-auto mb-3 font-bold text-navy-900/70">1</div>
          <h3 class="font-semibold text-navy-900">Lead captured</h3>
          <p class="text-xs text-navy-900/65 mt-1">AI scores and routes</p>
        </div>
        <div class="flex-1 rounded-xl bg-surface-50 border border-black/10 p-5 text-center">
          <div class="w-9 h-9 rounded-full bg-prizm-50 text-prizm-700 flex items-center justify-center mx-auto mb-3 font-bold">2</div>
          <h3 class="font-semibold text-navy-900">Qualified</h3>
          <p class="text-xs text-navy-900/65 mt-1">Needs assessed</p>
        </div>
        <div class="flex-1 rounded-xl bg-surface-50 border border-black/10 p-5 text-center">
          <div class="w-9 h-9 rounded-full bg-prizm-50 text-prizm-700 flex items-center justify-center mx-auto mb-3 font-bold">3</div>
          <h3 class="font-semibold text-navy-900">Quote sent</h3>
          <p class="text-xs text-navy-900/65 mt-1">AI-generated quote</p>
        </div>
        <div class="flex-1 rounded-xl bg-prizm-50 border border-prizm-500/30 p-5 text-center">
          <div class="w-9 h-9 rounded-full bg-prizm-500 text-white flex items-center justify-center mx-auto mb-3 font-bold">4</div>
          <h3 class="font-semibold text-navy-900">Booked</h3>
          <p class="text-xs text-navy-900/65 mt-1">Customer converted</p>
        </div>
      </div>

      <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-5">
        <div class="rounded-xl bg-surface-50 border border-black/10 p-5 text-center reveal">
          <div class="text-3xl font-extrabold text-prizm-600">3.2x</div>
          <p class="mt-1 text-xs text-navy-900/70">Better lead conversion</p>
        </div>
        <div class="rounded-xl bg-surface-50 border border-black/10 p-5 text-center reveal">
          <div class="text-3xl font-extrabold text-navy-900">40%</div>
          <p class="mt-1 text-xs text-navy-900/70">Shorter sales cycle</p>
        </div>
        <div class="rounded-xl bg-surface-50 border border-black/10 p-5 text-center reveal">
          <div class="text-3xl font-extrabold text-navy-900">100%</div>
          <p class="mt-1 text-xs text-navy-900/70">Pipeline visibility</p>
        </div>
        <div class="rounded-xl bg-surface-50 border border-black/10 p-5 text-center reveal">
          <div class="text-3xl font-extrabold text-navy-900">Zero</div>
          <p class="mt-1 text-xs text-navy-900/70">Leads fall through cracks</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why not generic CRM -->
  <section class="bg-surface-50 py-20">
    <div class="max-w-5xl mx-auto px-6">
      <p class="eyebrow reveal">Why not Salesforce or HubSpot?</p>
      <h2 class="mt-3 text-h2 font-bold text-navy-900 reveal">Generic CRMs need months of customization — and still won't understand freight.</h2>

      <div class="mt-10 rounded-2xl border border-black/10 overflow-hidden reveal">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-navy-900 text-white">
                <th class="text-left font-semibold px-6 py-4">Capability</th>
                <th class="text-center font-semibold px-6 py-4 text-white/70">Generic CRMs</th>
                <th class="text-center font-semibold px-6 py-4 text-prizm-400">LogisticsPrizm CRM</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-black/5 bg-white">
              <tr><td class="px-6 py-4 font-medium text-navy-900">Logistics lead scoring</td><td class="px-6 py-4 text-navy-900/70 text-center">Custom build required</td><td class="px-6 py-4 text-center font-semibold text-navy-900">Built-in, 6 factors</td></tr>
              <tr class="bg-surface-50"><td class="px-6 py-4 font-medium text-navy-900">Lane & mode tracking</td><td class="px-6 py-4 text-navy-900/70 text-center">Not supported</td><td class="px-6 py-4 text-center font-semibold text-navy-900">Native support</td></tr>
              <tr><td class="px-6 py-4 font-medium text-navy-900">Quote-to-shipment pipeline</td><td class="px-6 py-4 text-navy-900/70 text-center">Needs customization</td><td class="px-6 py-4 text-center font-semibold text-navy-900">Default workflow</td></tr>
              <tr class="bg-surface-50"><td class="px-6 py-4 font-medium text-navy-900">Shipment history on contact</td><td class="px-6 py-4 text-navy-900/70 text-center">Integration needed</td><td class="px-6 py-4 text-center font-semibold text-navy-900">Automatic</td></tr>
              <tr><td class="px-6 py-4 font-medium text-navy-900">Time to value</td><td class="px-6 py-4 text-navy-900/70 text-center">3–6 months setup</td><td class="px-6 py-4 text-center font-semibold text-navy-900">Same day</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <FinalCTA />
</BaseLayout>
