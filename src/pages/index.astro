---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroVideo from '@/components/HeroVideo.astro';
import LogoStrip from '@/components/sections/LogoStrip.astro';
import ProblemAgitation from '@/components/sections/ProblemAgitation.astro';
import SolutionBridge from '@/components/sections/SolutionBridge.astro';
import FeatureGrid from '@/components/sections/FeatureGrid.astro';
import ProofStack from '@/components/sections/ProofStack.astro';
import ITARMoat from '@/components/sections/ITARMoat.astro';
import PricingTiers from '@/components/sections/PricingTiers.astro';
import FAQ from '@/components/sections/FAQ.astro';
import FounderLetter from '@/components/sections/FounderLetter.astro';
