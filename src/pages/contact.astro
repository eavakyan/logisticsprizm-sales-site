---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CONTACT, APP_LINKS, CALENDLY_URL } from '@/lib/links';
---
<BaseLayout
  title="Contact LogisticsPrizm"
  description="Sales, support, and partnerships."
  breadcrumbs={[
    { name: 'Home', url: 'https://logisticsprizm.com/' },
    { name: 'Contact', url: 'https://logisticsprizm.com/contact' },
  ]}
>
  <section class="py-24 bg-surface-50">
    <div class="max-w-4xl mx-auto px-6">
      <p class="eyebrow">Contact</p>
      <h1 class="mt-3 text-h1 font-bold text-navy-900">Contact the LogisticsPrizm team.</h1>
      <p class="mt-3 text-xl text-navy-900/70">Talk to a human. Sales, support, partnerships.</p>

      <div class="mt-12 grid md:grid-cols-3 gap-5">
        <div class="rounded-2xl bg-white border border-black/10 p-6">
          <div class="font-mono text-xs text-prizm-600 uppercase tracking-wider">Sales</div>
          <h3 class="mt-2 text-xl font-bold text-navy-900">Looking at the product</h3>
          <a href={`mailto:${CONTACT.salesEmail}`} class="mt-3 block text-prizm-600 font-semibold">{CONTACT.salesEmail}</a>
          <a href={CALENDLY_URL} target="_blank" rel="noopener" class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-navy-900 hover:text-prizm-600">Book a demo →</a>
        </div>
        <div class="rounded-2xl bg-white border border-black/10 p-6">
          <div class="font-mono text-xs text-prizm-600 uppercase tracking-wider">Support</div>
          <h3 class="mt-2 text-xl font-bold text-navy-900">Founding Customer</h3>
          <a href={`mailto:${CONTACT.supportEmail}`} class="mt-3 block text-prizm-600 font-semibold">{CONTACT.supportEmail}</a>
          <a href={APP_LINKS.login} class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-navy-900 hover:text-prizm-600">Sign in →</a>
        </div>
        <div class="rounded-2xl bg-white border border-black/10 p-6">
          <div class="font-mono text-xs text-prizm-600 uppercase tracking-wider">Partners</div>
          <h3 class="mt-2 text-xl font-bold text-navy-900">Carriers, resellers, agencies</h3>
          <a href={`mailto:${CONTACT.partnersEmail}`} class="mt-3 block text-prizm-600 font-semibold">{CONTACT.partnersEmail}</a>
        </div>
      </div>

      <p class="mt-10 text-sm text-navy-900/55 max-w-prose">
        LogisticsPrizm is pre-launch. We are an independently funded software team rather than a traditional
        office-based operation; we route all inbound through the shared inboxes above.
      </p>
      <p class="mt-3 text-xs text-navy-900/55 max-w-prose">
        LogisticsPrizm is a trade name (DBA) of <strong>VUGA Enterprises LLC</strong>.
      </p>
    </div>
  </section>
</BaseLayout>
