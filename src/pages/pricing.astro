---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PricingTiers from '@/components/sections/PricingTiers.astro';
import FAQ from '@/components/sections/FAQ.astro';
import FinalCTA from '@/components/sections/FinalCTA.astro';
---
<BaseLayout
  title="LogisticsPrizm pricing — four plans, no implementation fees"
  description="$149–$2,499 per month. Monthly or annual. Founding Customer pricing 40% off through Q3 2026. No implementation fees, no hidden charges."
>
  <section class="pt-24 pb-10 bg-navy-900 text-white">
    <div class="max-w-5xl mx-auto px-6">
      <p class="eyebrow text-prizm-400">Pricing</p>
      <h1 class="mt-3 text-h1 font-bold">Transparent. Monthly. No ceremonies.</h1>
      <p class="mt-4 text-lg text-white/80 max-w-2xl">
        Enterprise TMS vendors like CargoWise are priced for $50M+ forwarders; their published
        pricing starts in the thousands per month plus multi-month onboarding. Our list prices are on
        this page. Founding Customer pricing (40% off first year) runs through Q3 2026.
      </p>
    </div>
  </section>

  <PricingTiers />

  <section class="bg-surface-50 py-24">
    <div class="max-w-6xl mx-auto px-6">
      <p class="eyebrow reveal">Beyond the subscription</p>
      <h2 class="mt-3 text-h2 font-bold text-navy-900 reveal">Consulting &amp; custom services</h2>
      <p class="mt-4 text-navy-900/75 max-w-prose reveal">
        For teams that want hands-on help. Every plan can be paired with:
      </p>

      <div class="mt-10 grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="rounded-xl border border-black/10 bg-white p-6 reveal">
          <div class="font-mono text-xs text-prizm-600 uppercase tracking-wider">Implementation</div>
          <div class="mt-2 text-xl font-bold text-navy-900">$2.5K – $50K</div>
          <p class="mt-2 text-sm text-navy-900/70">Rate-card migration, carrier integrations, historical data import, team training.</p>
        </div>
        <div class="rounded-xl border border-black/10 bg-white p-6 reveal">
          <div class="font-mono text-xs text-prizm-600 uppercase tracking-wider">Custom development</div>
          <div class="mt-2 text-xl font-bold text-navy-900">$165 – $250 / hr</div>
          <p class="mt-2 text-sm text-navy-900/70">Bespoke carrier adapters, white-label portals, accounting integrations.</p>
        </div>
        <div class="rounded-xl border border-black/10 bg-white p-6 reveal">
          <div class="font-mono text-xs text-prizm-600 uppercase tracking-wider">Strategic consulting</div>
          <div class="mt-2 text-xl font-bold text-navy-900">$5K – $75K</div>
          <p class="mt-2 text-sm text-navy-900/70">Process redesign, AI adoption roadmap, M&amp;A tech due diligence.</p>
        </div>
        <div class="rounded-xl border border-black/10 bg-white p-6 reveal">
          <div class="font-mono text-xs text-prizm-600 uppercase tracking-wider">Managed services</div>
          <div class="mt-2 text-xl font-bold text-navy-900">$1.5K – $20K / mo</div>
          <p class="mt-2 text-sm text-navy-900/70">We operate your TMS day-to-day while your team focuses on customers.</p>
        </div>
      </div>
    </div>
  </section>

  <FAQ />
  <FinalCTA />
</BaseLayout>
