---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FinalCTA from '@/components/sections/FinalCTA.astro';
import { CALENDLY_URL } from '@/lib/links';

const title = 'ITAR-Compliant Logistics Software | Defense & Government Shipping';
const description = 'Purpose-built for ITAR compliance with on-premise AI processing. Handle defense shipments with confidence — your data never leaves your infrastructure.';
---
<BaseLayout
  title={title}
  description={description}
  breadcrumbs={[
    { name: 'Home', url: 'https://logisticsprizm.com/' },
    { name: 'Solutions', url: 'https://logisticsprizm.com/solutions' },
    { name: 'Defense & Government', url: 'https://logisticsprizm.com/solutions/defense-government' },
  ]}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'LogisticsPrizm Defense & Government Logistics Platform',
    description: 'ITAR-compliant logistics software with on-premise AI processing, automated audit trails, USML classification tracking, and export control workflows for defense and government shipping.',
    provider: { '@type': 'Organization', name: 'LogisticsPrizm' },
    serviceType: 'ITAR-Compliant Logistics Software',
    areaServed: 'United States',
    url: 'https://logisticsprizm.com/solutions/defense-government',
  })} />

  <!-- Hero (darker treatment, this one earns it) -->
  <section class="pt-24 pb-14 bg-ocean-midnight text-white">
    <div class="max-w-4xl mx-auto px-6">
      <p class="eyebrow text-ocean-mint">Solution · Defense-grade compliance</p>
      <h1 class="mt-3 text-h1 font-bold">
        Logistics software built for <span class="gradient-amber">defense-grade compliance</span>.
      </h1>
      <p class="mt-5 text-lg text-white/85 max-w-prose">
        ITAR violations carry criminal fines of $1M and up to 10 years imprisonment per violation.
        LogisticsPrizm is purpose-built for defense logistics with on-premise AI that keeps controlled
        data on your infrastructure.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a href={CALENDLY_URL} target="_blank" rel="noopener" class="inline-flex justify-center items-center gap-2 px-6 py-3 rounded-lg bg-prizm-500 text-white font-semibold hover:bg-prizm-600 transition-colors shadow-lg shadow-prizm-500/25">
          Get a custom quote <span aria-hidden>→</span>
        </a>
        <a href="#features" class="inline-flex justify-center items-center gap-2 px-6 py-3 rounded-lg bg-white/10 backdrop-blur text-white font-semibold hover:bg-white/20 transition-colors border border-white/15">
          See compliance features
        </a>
      </div>
    </div>
  </section>

  <!-- The Stakes -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-6">
      <p class="eyebrow reveal">The stakes are not optional</p>
      <h2 class="mt-3 text-h2 font-bold text-navy-900 reveal">ITAR compliance isn't a nice-to-have. It's the law.</h2>
      <p class="mt-4 text-navy-900/75 max-w-prose reveal">The penalties for violations are severe, and generic logistics software wasn't designed to protect you.</p>

      <div class="mt-12 grid md:grid-cols-3 gap-6">
        <div class="rounded-xl border border-black/10 bg-surface-50 p-7 reveal">
          <h3 class="text-lg font-semibold text-navy-900">$1M+ criminal fines</h3>
          <p class="mt-2 text-sm text-navy-900/75 leading-relaxed">Each ITAR violation can result in criminal fines up to $1 million and imprisonment up to 10 years. Civil penalties reach $500,000 per violation. One shipment can trigger multiple violations.</p>
        </div>
        <div class="rounded-xl border border-black/10 bg-surface-50 p-7 reveal">
          <h3 class="text-lg font-semibold text-navy-900">Data sovereignty risk</h3>
          <p class="mt-2 text-sm text-navy-900/75 leading-relaxed">Most logistics platforms process data through third-party cloud AI services. With ITAR-controlled articles, sending shipment data to external APIs can constitute an unauthorized export.</p>
        </div>
        <div class="rounded-xl border border-black/10 bg-surface-50 p-7 reveal">
          <h3 class="text-lg font-semibold text-navy-900">Audit exposure</h3>
          <p class="mt-2 text-sm text-navy-900/75 leading-relaxed">DDTC audits require complete records of every defense article shipment, every person who accessed data, and every system that processed it. Spreadsheets won't pass scrutiny.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="bg-surface-50 py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="eyebrow reveal">Purpose-built for defense logistics</p>
      <h2 class="mt-3 text-h2 font-bold text-navy-900 reveal">The only logistics platform with local AI, automated ITAR workflows, and defense-grade audit trails in its core.</h2>

      <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/itar" class="group rounded-xl bg-white border border-black/10 p-7 hover:border-prizm-500/40 transition-colors reveal">
          <h3 class="text-lg font-semibold text-navy-900 group-hover:text-prizm-600 transition-colors">Local AI processing</h3>
          <p class="mt-2 text-sm text-navy-900/75 leading-relaxed">Ollama + Mistral 7B runs entirely on your infrastructure. Quoting, analytics, and document processing happen locally. Zero data leaves your network. Zero third-party exposure.</p>
        </a>
        <div class="rounded-xl bg-white border border-black/10 p-7 reveal">
          <h3 class="text-lg font-semibold text-navy-900">Immutable audit trails</h3>
          <p class="mt-2 text-sm text-navy-900/75 leading-relaxed">Every action, access, and modification logged with tamper-proof timestamps. Pull complete DDTC-ready audit reports in seconds, with full chain of custody.</p>
        </div>
        <div class="rounded-xl bg-white border border-black/10 p-7 reveal">
          <h3 class="text-lg font-semibold text-navy-900">USML classification tracking</h3>
          <p class="mt-2 text-sm text-navy-900/75 leading-relaxed">Tag shipments with USML categories. Automated checks ensure proper authorization levels, destination restrictions, and end-use documentation before any defense article moves.</p>
        </div>
        <div class="rounded-xl bg-white border border-black/10 p-7 reveal">
          <h3 class="text-lg font-semibold text-navy-900">Export control workflows</h3>
          <p class="mt-2 text-sm text-navy-900/75 leading-relaxed">Built-in approval chains for export licenses, DSP-5/DSP-73 tracking, and automated holds on shipments that require additional authorization before release.</p>
        </div>
        <div class="rounded-xl bg-white border border-black/10 p-7 reveal">
          <h3 class="text-lg font-semibold text-navy-900">ITAR-mapped RBAC</h3>
          <p class="mt-2 text-sm text-navy-900/75 leading-relaxed">Role-based access control mapped to ITAR authorization levels. Six hierarchical roles ensure only authorized personnel access controlled article data and shipping information.</p>
        </div>
        <div class="rounded-xl bg-white border border-black/10 p-7 reveal">
          <h3 class="text-lg font-semibold text-navy-900">Defense-grade encryption</h3>
          <p class="mt-2 text-sm text-navy-900/75 leading-relaxed">AES-256 encryption at rest, TLS 1.3 in transit. All controlled article data is encrypted end-to-end with key management that meets defense industry standards.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Who it's for -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-6">
      <p class="eyebrow reveal">Built for defense logistics professionals</p>
      <h2 class="mt-3 text-h2 font-bold text-navy-900 reveal">Every stakeholder in the defense supply chain.</h2>

      <div class="mt-10 grid md:grid-cols-2 gap-6">
        <div class="rounded-xl border border-black/10 bg-surface-50 p-7 reveal">
          <h3 class="text-base font-semibold text-navy-900">Defense contractors</h3>
          <p class="mt-2 text-sm text-navy-900/75">Companies shipping controlled articles under USML categories who need automated compliance workflows and audit-ready documentation.</p>
        </div>
        <div class="rounded-xl border border-black/10 bg-surface-50 p-7 reveal">
          <h3 class="text-base font-semibold text-navy-900">ITAR-registered forwarders</h3>
          <p class="mt-2 text-sm text-navy-900/75">Freight forwarders with ITAR registration handling defense shipments who need data sovereignty and local AI processing.</p>
        </div>
        <div class="rounded-xl border border-black/10 bg-surface-50 p-7 reveal">
          <h3 class="text-base font-semibold text-navy-900">Government logistics</h3>
          <p class="mt-2 text-sm text-navy-900/75">Government agencies and military logistics operations that require the highest standards of data security and compliance tracking.</p>
        </div>
        <div class="rounded-xl border border-black/10 bg-surface-50 p-7 reveal">
          <h3 class="text-base font-semibold text-navy-900">Defense supply chain</h3>
          <p class="mt-2 text-sm text-navy-900/75">Supply-chain managers overseeing the movement of defense articles across contractors, subcontractors, and government facilities.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-surface-50 py-20">
    <div class="max-w-5xl mx-auto px-6">
      <p class="eyebrow reveal">Compliance is a competitive advantage</p>
      <h2 class="mt-3 text-h2 font-bold text-navy-900 reveal">ITAR-compliant companies win contracts non-compliant competitors can't bid on.</h2>

      <div class="mt-12 grid md:grid-cols-3 gap-6">
        <div class="rounded-xl bg-white border border-black/10 p-7 text-center reveal">
          <div class="text-4xl font-extrabold text-red-500 mb-2">$1M+</div>
          <div class="text-base font-semibold text-navy-900">Per ITAR violation</div>
          <p class="mt-2 text-sm text-navy-900/70">Criminal fines up to $1M and imprisonment up to 10 years per violation. Civil penalties up to $500K.</p>
        </div>
        <div class="rounded-xl bg-white border border-black/10 p-7 text-center reveal">
          <div class="text-4xl font-extrabold text-prizm-600 mb-2">Zero</div>
          <div class="text-base font-semibold text-navy-900">Third-party exposure</div>
          <p class="mt-2 text-sm text-navy-900/70">Local AI processing with Ollama ensures no controlled data is sent to external APIs, cloud services, or third-party processors.</p>
        </div>
        <div class="rounded-xl bg-white border border-black/10 p-7 text-center reveal">
          <div class="text-4xl font-extrabold text-ocean-mint mb-2">Day one</div>
          <div class="text-base font-semibold text-navy-900">Audit-ready</div>
          <p class="mt-2 text-sm text-navy-900/70">From your first shipment, every action is logged with immutable timestamps. Audit-ready from day one.</p>
        </div>
      </div>
    </div>
  </section>

  <FinalCTA />
</BaseLayout>
