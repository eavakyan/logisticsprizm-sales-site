---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout
  title="Page not found — LogisticsPrizm"
  description="The page you requested does not exist."
  noIndex={true}
>
  <section class="pt-24 pb-20 bg-surface-50">
    <div class="max-w-3xl mx-auto px-6">
      <p class="eyebrow">404</p>
      <h1 class="mt-3 text-h1 font-bold text-navy-900">
        We routed that one to the <span class="gradient-amber">wrong port.</span>
      </h1>
      <p class="mt-5 text-lg text-navy-900/80 max-w-prose">
        The page you requested does not exist — or has been moved. Pick a destination
        below and we&#39;ll get you back on a known lane.
      </p>

      <div class="mt-12 grid sm:grid-cols-2 gap-4">
        <a
          href="/"
          class="rounded-xl border border-black/10 bg-white p-6 hover:border-prizm-500 hover:shadow-md transition-all"
        >
          <div class="font-mono text-xs text-prizm-600 uppercase tracking-wider">Home</div>
          <div class="mt-2 text-lg font-bold text-navy-900">Back to the front page</div>
          <p class="mt-2 text-sm text-navy-900/65">The pitch in 60 seconds.</p>
        </a>
        <a
          href="/pricing"
          class="rounded-xl border border-black/10 bg-white p-6 hover:border-prizm-500 hover:shadow-md transition-all"
        >
          <div class="font-mono text-xs text-prizm-600 uppercase tracking-wider">Pricing</div>
          <div class="mt-2 text-lg font-bold text-navy-900">Four plans. List prices on the page.</div>
          <p class="mt-2 text-sm text-navy-900/65">$149&ndash;$2,499 / month. No implementation fees.</p>
        </a>
        <a
          href="/itar"
          class="rounded-xl border border-black/10 bg-white p-6 hover:border-prizm-500 hover:shadow-md transition-all"
        >
          <div class="font-mono text-xs text-prizm-600 uppercase tracking-wider">ITAR</div>
          <div class="mt-2 text-lg font-bold text-navy-900">Defense-grade compliance.</div>
          <p class="mt-2 text-sm text-navy-900/65">Built in, not bolted on.</p>
        </a>
        <a
          href="/request-demo"
          class="rounded-xl border border-black/10 bg-white p-6 hover:border-prizm-500 hover:shadow-md transition-all"
        >
          <div class="font-mono text-xs text-prizm-600 uppercase tracking-wider">Book a demo</div>
          <div class="mt-2 text-lg font-bold text-navy-900">20 minutes. Your lanes.</div>
          <p class="mt-2 text-sm text-navy-900/65">We pre-load a sandbox with your real data.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
