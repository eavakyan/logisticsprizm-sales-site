---
import { APP_LINKS, NAV_LINKS, CALENDLY_URL } from '@/lib/links';
---
<header id="top" class="sticky top-0 z-40 bg-surface-50/80 backdrop-blur-md border-b border-black/5">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-bold tracking-tight">
      <span class="inline-flex w-8 h-8 rounded-lg bg-gradient-to-br from-prizm-500 to-prizm-600 items-center justify-center text-white text-sm">✦</span>
      <span class="text-navy-900 text-lg">LogisticsPrizm</span>
    </a>

    <nav class="hidden md:flex items-center gap-7 text-sm font-medium text-navy-900/80">
      {NAV_LINKS.map(l => (
        <a href={l.href} class="hover:text-prizm-600 transition-colors">{l.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={APP_LINKS.login}
        class="hidden sm:inline text-sm font-medium text-navy-900/80 hover:text-prizm-600 transition-colors"
      >Sign in</a>
      <a
        href={CALENDLY_URL}
        target="_blank"
        rel="noopener"
        class="text-sm font-semibold px-4 py-2 rounded-lg bg-prizm-500 text-white hover:bg-prizm-600 transition-colors shadow-sm"
      >Book demo</a>
    </div>
  </div>
</header>
