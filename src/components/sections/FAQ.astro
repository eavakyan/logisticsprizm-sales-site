---
// Reframed for pre-launch honesty. Removed the "most forwarders who call us" framing
// and the fake Shenzhen-LA testimonial. Each answer tells the truth about where the
// product is today.
const faq = [
  {
    q: 'Is this product live today?',
    a: "LogisticsPrizm is in Founding Customer onboarding. The platform is fully built — authentication, AI quoting, tracking, invoice reconciliation, compliance screening, and financials are all operational. We are intentionally limiting the first cohort so every customer gets hands-on help from the team. If you'd like to be part of that cohort, book a demo and we'll scope a pilot together.",
  },
  {
    q: "We already use CargoWise. Do we have to rip it out?",
    a: "No. Most mid-market forwarders we talk to want to run LogisticsPrizm alongside their existing TMS first, starting with the pieces CargoWise and Descartes price out of reach — AI quoting, invoice reconciliation, lead scoring, ITAR workflow. If and when you want to migrate fully, that happens on your timeline.",
  },
  {
    q: "How long does onboarding take?",
    a: "Solo and Growth: self-serve, you can be creating real quotes the same day. Professional: a structured 2–3 week onboarding with a dedicated contact. Enterprise: 4–6 weeks to include data migration, SSO, and carrier integrations. We do not quote six-month rollouts because we do not take six months.",
  },
  {
    q: "Our carriers don't support webhooks. Now what?",
    a: "Same answer as the rest of the industry: we poll their tracking APIs on a schedule and normalize into one event stream. For carriers that only send EDI, a lightweight adapter sits in between. The customer-facing timeline looks identical whichever path the data came in through.",
  },
  {
    q: "Where does our data live? Who can see it?",
    a: "Primary data resides in US-based VPS infrastructure with daily encrypted backups to a secondary region. Every tenant is isolated at the database layer with Row-Level Security — not just application code. For ITAR customers, AI inference can run on a US-only Ollama instance; cargo descriptions do not leave your network.",
  },
  {
    q: "Can the AI quote use rates we've negotiated?",
    a: "Yes — that is what the Rate Card editor is for. Upload your NAC, FAK, or spot agreements, tag them by lane and mode, and the engine uses them first before consulting spot-market data. It is your pricing discipline, automated.",
  },
  {
    q: "What happens if the AI gets a quote wrong?",
    a: "Every AI-generated quote shows its confidence score and the similar historical quotes it used as references. Your rep reviews both before the quote goes out. Quotes below a configurable confidence threshold are flagged for manual review. The AI augments; it does not autopilot.",
  },
  {
    q: "Do you integrate with QuickBooks / NetSuite / Sage?",
    a: "Journal entries, A/R aging reports, and invoice batches can be exported on a schedule to all three. A direct QuickBooks Online sync is on the near-term roadmap; Professional and Enterprise customers can request priority scheduling.",
  },
  {
    q: "Pricing seems low. What's the catch?",
    a: "No catch. Our infrastructure is bare-metal, not a cloud reseller, and we do not charge per shipment because per-shipment pricing punishes customer growth. Founding Customer pricing (40% off first year) is limited to the first cohort and ends Q3 2026.",
  },
];
---
<section class="bg-surface-50 py-24 md:py-32">
  <div class="max-w-4xl mx-auto px-6">
    <p class="eyebrow reveal">What ops leaders actually ask</p>
    <h2 class="mt-3 text-h1 font-bold text-navy-900 reveal">Frequently asked, honestly answered.</h2>

    <div class="mt-12 divide-y divide-black/10 border-y border-black/10">
      {faq.map((item, i) => (
        <details class="group py-5 reveal">
          <summary class="flex cursor-pointer list-none items-start gap-4 text-navy-900">
            <span class="font-mono text-xs text-prizm-600 pt-1 w-8 shrink-0">{String(i + 1).padStart(2, '0')}</span>
            <span class="font-semibold text-lg flex-1">{item.q}</span>
            <span class="text-prizm-600 transition-transform group-open:rotate-45 text-2xl leading-none pt-0.5">+</span>
          </summary>
          <div class="mt-4 pl-12 max-w-prose text-navy-900/75 leading-relaxed">
            {item.a}
          </div>
        </details>
      ))}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.a,
      },
    })),
  })} />
</section>
